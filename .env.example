# Site Configuration
VITE_SITE_URL=https://epmartins.com.br

# Google Analytics 4 (GA4)
# Obter em: Google Analytics → Administrador → Propriedades → Fluxo de dados → ID de Medição
# Formato: G-XXXXXXXXXX
VITE_GA_MEASUREMENT_ID=

# Google Tag Manager (GTM) - Opcional mas recomendado
# Obter em: Google Tag Manager → Administrador → Contas e Contêineres → ID do Contêiner
# Formato: GTM-XXXXXX
VITE_GTM_ID=

# Google Ads Conversion Tracking
# Obter em: Google Ads → Ferramentas → Conversões → ID da Conta
# Formato: AW-XXXXXXXXXX
VITE_GOOGLE_ADS_ID=

# Google Ads Conversion Label
# Obter em: Google Ads → Ferramentas → Conversões → Rótulo de Conversão
# Exemplo: AW-123456789/AbCdEfGhIjKlMnOpQr (sem espaços)
VITE_GOOGLE_ADS_CONVERSION_LABEL=

# Instruções completas em: ANALYTICS_SETUP.md
